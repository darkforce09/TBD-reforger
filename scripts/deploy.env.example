# Copy to scripts/deploy.env (gitignored) and fill in values.
# TBD deploy targets /home/sam/tbd/ only — never /home/sam/prairielearn/
#
# Dev PC prereqs: sshpass (dnf install sshpass), rsync, node 18+, cd tbd-schema && npm ci

# SSH (PrairieLearn-style sshpass, or leave TBD_SSH_PASS empty and set TBD_SSH_IDENTITY_FILE)
TBD_SSH_HOST=sam@192.168.0.140
TBD_SSH_PASS=
TBD_SSH_IDENTITY_FILE=

# Remote paths
TBD_REMOTE_DIR=/home/sam/tbd/repo
TBD_PROFILE_DIR=/home/sam/tbd/profile
TBD_ADDONS_STAGING=/home/sam/tbd/addons-staging
TBD_SERVER_DIR=/home/sam/steam/arma-reforger-server

# Game + API (TBD_GAME_SERVER_TOKEN must match GAME_SERVER_TOKENS in server Tbdevent_Website/.env)
TBD_GAME_SERVER_TOKEN=
TBD_MISSION_ID=msn_8f3a2c
TBD_EVENT_ID=b0000000-0000-4000-8000-000000000001
TBD_BACKEND_URL=http://127.0.0.1:8080

# Enfusion (see tbd-framework/addon.gproj and scripts/run-dev-server.sh)
TBD_ADDON_GUID=B2C3D4E5F6A78901
TBD_SCENARIO={69A85365FC09E2CA}Missions/TBD_Dev_POC.conf

# Optional legacy; Direct Join uses bindPort 2001. Server binds 0.0.0.0 with A2S on same port.
# TBD_BIND_IP=192.168.0.140

# Optional: host Postgres port if 5432 is taken on the server (docker-compose.staging.yml)
TBD_POSTGRES_HOST_PORT=5432
