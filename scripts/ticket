#!/usr/bin/env bash
# Ticket registry + batch pipeline — T-161.4: thin wrapper → cargo xtask
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

usage() {
  cat <<EOF
Usage: ./scripts/ticket <command> [args]

Registry (edit .ai/tickets/registry.json, then sync):
  sync                    Regenerate all derived outputs
  check [--strict]        Validate registry + outputs
  next                    Show active slice + next queued tickets
  brief ID                Developer handoff for one ticket
  prompt ID [--slice SLICE] [--header]
                          Print Claude Code prompt from active slice spec
  show ID                 One ticket card
  add TITLE [opts]        Add idea ticket
  remove ID               Remove ticket row
  reorder ID AFTER        Set order after another ticket
  mark-ready ID [SPEC]    Mark ready in registry + sync
  ship ID                 Mark shipped in registry + sync
  plan-batch              List next batch candidates
  advance-slice ID        Bump active_slice to next in slices[]
  milestone M1            Show milestone gate progress
  list                    Show dev queue
  ready-ids / get / config / set-status
                          Queue helpers (used by run/clean)

Pipeline:
  run [--dry-run] [--stream NAME]  Implement up to batch_size ready tickets
  done ID                 After merge: cleanup + mark shipped
  clean ID                Remove worktree + local branch only

Implementation: cargo xtask ticket … (T-161 Rust port).
EOF
}

case "${1:-}" in
  help|-h|"")
    usage
    exit 0
    ;;
esac

# Quiet cargo chatter so stdout/stderr match the old Python CLI.
exec cargo run -q -p xtask -- ticket "$@"
