{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.tbdevent.eu/registry/v1.json",
  "title": "TBD Registry",
  "description": "Maps mission registry aliases to engine prefab GUIDs plus web display metadata. Generated by the TBD-Content Workbench export tool. Missions and the wizard speak only aliases; the framework resolves them through this file at load.",
  "type": "object",
  "required": ["registryVersion", "entries"],
  "additionalProperties": false,
  "properties": {
    "registryVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "modset": {
      "type": "array",
      "description": "Workshop mods this registry resolves against.",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "workshopId": { "type": "string" }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["alias", "guid", "displayName"],
      "additionalProperties": false,
      "properties": {
        "alias": {
          "type": "string",
          "pattern": "^(kit|comp|veh|preset|layer|prop|item):[a-z0-9_]+$"
        },
        "guid": {
          "type": "string",
          "description": "Enfusion ResourceName ({GUID}Prefabs/.../File.et) used by Resource.Load. Bare GUID-only values are reserved for future catalog lookup.",
          "pattern": "^\\{[0-9A-F]{16}\\}[A-Za-z0-9/_.\\-]+$"
        },
        "displayName": { "type": "string", "minLength": 1 },
        "thumbnail": { "type": "string" },
        "footprint": {
          "type": "object",
          "description": "Optional footprint the web map renders for placeable compositions.",
          "oneOf": [
            {
              "required": ["radius"],
              "additionalProperties": false,
              "properties": { "radius": { "type": "number", "exclusiveMinimum": 0 } }
            },
            {
              "required": ["box"],
              "additionalProperties": false,
              "properties": {
                "box": {
                  "type": "array",
                  "items": { "type": "number", "exclusiveMinimum": 0 },
                  "minItems": 2,
                  "maxItems": 2
                }
              }
            }
          ]
        }
      }
    }
  }
}
