# Server
PORT=8080
APP_ENV=development

# Frontend integration
# SPA base URL the OAuth callback redirects to (tokens land at FRONTEND_URL/auth/callback#...)
FRONTEND_URL=http://127.0.0.1:3000
# CORS allow-list (comma-separated). Dev uses the Trunk proxy, so this matters in production.
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# T-159 Leptos SPA cutover (leave blank in dev — `make leptos` / `trunk serve` owns the SPA on :3000):
#   - SPA_DIST_DIR: when set, the API serves the built Leptos SPA statically (COOP/COEP + SPA
#     fallback) AND /map-assets, so the app runs same-origin with the API (no separate web host).
#     At the flip, set to the leptos dist and point FRONTEND_URL/ALLOWED_ORIGINS/the Discord app
#     redirect URI at the API's own origin (e.g. https://app.example.com) instead of :5173.
#   - MAP_ASSETS_DIR: the map-assets dir served at /map-assets (defaults to ../../packages/map-assets).
# SPA_DIST_DIR=apps/website-leptos/dist
# MAP_ASSETS_DIR=packages/map-assets

# Database (required)
DATABASE_URL=postgres://tbd:tbd@localhost:5434/tbd_reforger?sslmode=disable

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MIN=15

# Discord OAuth2 + role sync
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=http://localhost:8080/api/v1/auth/discord/callback
DISCORD_GUILD_ID=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# Game-server telemetry ingest auth
SERVICE_TOKEN=change-me-service-token
