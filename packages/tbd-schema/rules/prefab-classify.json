{
  "schemaVersion": "1.0.0",
  "description": "Shared prefab classification rules — apply to ALL terrains on export. Rules MUST emit structured gameplay, spatial, and render.iconKey for Eden AI + glyphs. See t090_eden_ai_world_object_schema.md and t090_world_object_glyphs.md.",
  "rules": [
    {
      "match": { "resourceNameContains": ["Tree_Pinus", "Tree_Spruce", "Conifer"] },
      "kind": "tree",
      "class": "conifer",
      "ai": {
        "summary": "Conifer tree; static vegetation; soft cover to ~4 m standing.",
        "taxonomyPath": "vegetation/tree/conifer",
        "confidence": 0.9
      },
      "spatial": {
        "model": "obb",
        "pivot": "base",
        "halfExtentsM": { "x": 1.2, "y": 1.2, "z": 6 },
        "heightM": 12
      },
      "gameplay": {
        "cover": { "type": "soft", "standing": true, "prone": true, "crouch": true, "heightM": 4 },
        "movement": { "blocksInfantry": false, "blocksVehicle": false },
        "lineOfSight": "partial",
        "destructible": true,
        "climbable": false,
        "enterable": false,
        "ladder": false,
        "door": false,
        "bridge": false,
        "runway": false
      },
      "render": {
        "iconKey": "tree-conifer",
        "lodMinZoom": 3,
        "baseSizePx": 24,
        "anchor": [0.5, 1.0],
        "defaultColor": "#2d5a27"
      }
    },
    {
      "match": { "resourceNameContains": ["Tree_Betula", "Tree_Quercus", "Deciduous"] },
      "kind": "tree",
      "class": "deciduous",
      "ai": {
        "summary": "Deciduous tree; static vegetation; soft cover.",
        "taxonomyPath": "vegetation/tree/deciduous",
        "confidence": 0.9
      },
      "spatial": {
        "model": "obb",
        "pivot": "base",
        "halfExtentsM": { "x": 1.5, "y": 1.5, "z": 5 },
        "heightM": 10
      },
      "gameplay": {
        "cover": { "type": "soft", "standing": true, "prone": true, "crouch": true, "heightM": 3.5 },
        "movement": { "blocksInfantry": false, "blocksVehicle": false },
        "lineOfSight": "partial",
        "destructible": true,
        "climbable": false,
        "enterable": false,
        "ladder": false,
        "door": false,
        "bridge": false,
        "runway": false
      },
      "render": {
        "iconKey": "tree-deciduous",
        "lodMinZoom": 3,
        "baseSizePx": 24,
        "anchor": [0.5, 1.0],
        "defaultColor": "#4a7a32"
      }
    },
    {
      "match": { "resourceNameContains": ["Road_", "Asphalt", "Highway"] },
      "kind": "road",
      "class": "road_paved",
      "ai": {
        "summary": "Paved road segment; no cover; vehicle route.",
        "taxonomyPath": "infrastructure/road/paved",
        "confidence": 0.85
      },
      "spatial": { "model": "line", "pivot": "base", "widthM": 6, "heightM": 0 },
      "gameplay": {
        "cover": { "type": "none", "standing": false, "prone": false, "crouch": false, "heightM": 0 },
        "movement": { "blocksInfantry": false, "blocksVehicle": false },
        "lineOfSight": "none",
        "destructible": false,
        "climbable": false,
        "enterable": false,
        "ladder": false,
        "door": false,
        "bridge": false,
        "runway": false
      }
    },
    {
      "match": { "resourceNameContains": ["House", "Village", "Residential"] },
      "kind": "building",
      "class": "residential",
      "ai": {
        "summary": "Residential building; hard cover; blocks movement and LOS.",
        "taxonomyPath": "structure/building/residential",
        "confidence": 0.85
      },
      "spatial": {
        "model": "obb",
        "pivot": "center",
        "halfExtentsM": { "x": 5, "y": 5, "z": 4 },
        "heightM": 8,
        "footprintM2": 100
      },
      "gameplay": {
        "cover": { "type": "hard", "standing": true, "prone": true, "crouch": true, "heightM": 2.5 },
        "movement": { "blocksInfantry": true, "blocksVehicle": true },
        "lineOfSight": "full",
        "destructible": true,
        "climbable": false,
        "enterable": true,
        "ladder": false,
        "door": true,
        "bridge": false,
        "runway": false
      },
      "render": {
        "iconKey": "building-residential",
        "lodMinZoom": 4,
        "baseSizePx": 16,
        "anchor": [0.5, 0.5]
      }
    }
  ],
  "fallback": {
    "kind": "prop",
    "class": "unknown",
    "ai": {
      "summary": "Unclassified static map prop; needs classification rule.",
      "taxonomyPath": "misc/unknown",
      "confidence": 0.0,
      "needsReview": true
    },
    "spatial": {
      "model": "obb",
      "pivot": "base",
      "halfExtentsM": { "x": 0.5, "y": 0.5, "z": 1 },
      "heightM": 1
    },
    "gameplay": {
      "cover": { "type": "none", "standing": false, "prone": false, "crouch": false, "heightM": 0 },
      "movement": { "blocksInfantry": false, "blocksVehicle": false },
      "lineOfSight": "none",
      "destructible": false,
      "climbable": false,
      "enterable": false,
      "ladder": false,
      "door": false,
      "bridge": false,
      "runway": false
    },
    "render": {
      "iconKey": "prop-unknown",
      "lodMinZoom": 4,
      "baseSizePx": 12,
      "anchor": [0.5, 1.0]
    }
  }
}
