{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.tbdevent.eu/terrain-anchors/v1.json",
  "title": "TBD Terrain Anchor Verification",
  "description": "GetSurfaceY probe log for T-091.0 anchor gate. demYM filled by verify-terrain-alignment.ts after DEM lands.",
  "type": "object",
  "required": ["terrainId", "schemaVersion", "thresholdM", "anchors"],
  "additionalProperties": false,
  "properties": {
    "terrainId": {
      "type": "string",
      "minLength": 1,
      "description": "Terrain key — same namespace as terrain-registry.json."
    },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "thresholdM": {
      "type": "number",
      "description": "Max allowed |demYM - surfaceYM| in meters. Default 1.0 until tuned."
    },
    "probedAt": { "type": "string", "format": "date-time" },
    "workbenchVersion": { "type": "string" },
    "demSource": { "type": "string" },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "x", "z", "surfaceYM"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "x": { "type": "number" },
          "z": { "type": "number" },
          "surfaceYM": {
            "type": "number",
            "description": "Meters ASL from mod GetSurfaceY(x,z) at probe time"
          },
          "demYM": {
            "type": "number",
            "description": "Filled by verify-terrain-alignment.ts after DEM sample"
          },
          "deltaM": { "type": "number" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
