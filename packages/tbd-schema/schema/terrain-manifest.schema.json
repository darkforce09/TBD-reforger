{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.tbdevent.eu/terrain-manifest/v1.json",
  "title": "TBD Terrain Manifest",
  "description": "Per-terrain map asset manifest (DEM + optional tile pyramid). Values for pixel dimensions and height range must come from World Editor Info & Diags at export — do not guess.",
  "type": "object",
  "required": [
    "terrainId",
    "schemaVersion",
    "worldBounds",
    "metersPerPixel",
    "dem",
    "precision"
  ],
  "additionalProperties": false,
  "properties": {
    "terrainId": {
      "type": "string",
      "minLength": 1,
      "description": "Terrain key — must match an entry in terrain-registry.json (same id namespace as packages/map-assets/{terrainId}/)."
    },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "worldBounds": {
      "type": "array",
      "description": "[minX, minY, maxX, maxY] meters — must match coords/terrains.ts",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "metersPerPixel": {
      "type": "number",
      "description": "Planar resolution from Info & Diags (Everon Biki: 2 m)."
    },
    "dem": {
      "type": "object",
      "required": [
        "path",
        "widthPx",
        "heightPx",
        "encoding",
        "heightRangeMinM",
        "heightRangeMaxM",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "widthPx": { "type": "integer", "minimum": 0, "description": "0 = stub awaiting T-091.0 export" },
        "heightPx": { "type": "integer", "minimum": 0, "description": "0 = stub awaiting T-091.0 export" },
        "encoding": { "const": "uint16-linear" },
        "heightRangeMinM": { "type": "number" },
        "heightRangeMaxM": { "type": "number" },
        "blackMapsToM": { "type": "number" },
        "whiteMapsToM": { "type": "number" },
        "source": {
          "type": "string",
          "enum": [
            "reforger-world-editor-base-png",
            "reforger-world-editor-modified-png",
            "asc-converted",
            "mod-getsurfacey-resample"
          ]
        },
        "exportedAt": { "type": "string", "format": "date-time" },
        "workbenchVersion": { "type": "string" },
        "axisFlip": {
          "type": "object",
          "properties": {
            "x": { "type": "boolean" },
            "z": { "type": "boolean" }
          }
        }
      }
    },
    "tiles": {
      "type": "object",
      "description": "Dual basemap pyramids (T-090.1/.1.1, N9). Legacy single `urlTemplate` = satellite alias (live everon manifest unchanged). `satellite` + `map` are the Google-Maps-style switchable views; both share bounds/zoom and the XYZ disk layout + fetch-time Y inversion.",
      "properties": {
        "type": { "const": "xyz" },
        "indexOrder": { "type": "string", "enum": ["xyz", "tms"] },
        "urlTemplate": { "type": "string" },
        "tileSizePx": { "type": "integer" },
        "minZoom": { "type": "integer" },
        "maxZoom": { "type": "integer" },
        "bounds": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "alignmentOrigin": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "satellite": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "urlTemplate": { "type": "string" },
            "source": {
              "type": "string",
              "enum": ["workbench-ortho", "sap", "sap-supertexture-stitch", "color-ortho"]
            },
            "encoding": {
              "type": "string",
              "description": "Tile codec — webp-lossless (VP8L) for the picture-perfect satellite pyramid (T-090.1.2.1); webp-lossy (VP8 q=N) for interim/dev builds.",
              "enum": ["webp-lossy", "webp-lossless", "png"]
            },
            "delivery": {
              "type": "string",
              "description": "Primary satellite delivery (T-090.1.2.8): unified = one tbd-sat bundle → single GPU texture with mips; pyramid = legacy per-viewport {z}/{x}/{y} tiles. The frontend falls back to the pyramid when the unified bundle is missing/unreadable.",
              "enum": ["pyramid", "unified"]
            },
            "waterComposite": {
              "type": "boolean",
              "description": "T-090.1.2.5 — true when the satellite ortho has engine-sourced hydrology composited on (ocean = DEM <= sea level; inland = supertexture water appearance, DEM-filtered). Provenance: staging TBD_SatExport_meta.json waterComposite block + .ai/artifacts/t090_1_2_5_water_source_spike.json."
            },
            "unified": {
              "type": "object",
              "description": "Unified satellite bundle (tbd-sat v1, T-090.1.2.8): GLB-style container of lossless-WebP mip blocks, fetched once and uploaded as a single mipmapped GPU texture.",
              "additionalProperties": false,
              "required": ["path", "url", "encoding"],
              "properties": {
                "path": { "type": "string" },
                "url": { "type": "string" },
                "encoding": { "const": "tbd-sat-v1" },
                "baseWidthPx": { "type": "integer", "minimum": 1 },
                "baseHeightPx": { "type": "integer", "minimum": 1 },
                "mipCount": { "type": "integer", "minimum": 1 },
                "bytes": { "type": "integer", "minimum": 1 }
              }
            }
          }
        },
        "map": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "urlTemplate": { "type": "string" },
            "source": {
              "type": "string",
              "description": "N9 — synthesized-cartographic = DEM hillshade + land-cover LUT + baked road vectors when Workbench has no cartographic export; UI labels it \"Synthetic map\".",
              "enum": ["workbench-cartographic", "synthesized-cartographic"]
            },
            "encoding": {
              "type": "string",
              "description": "Tile codec — webp-lossy (VP8 q=N) is the Map-view default (stylized cartographic raster, T-090.1.1); lossless is a satellite-only requirement.",
              "enum": ["webp-lossy", "webp-lossless", "png"]
            }
          }
        }
      }
    },
    "objects": {
      "type": "object",
      "description": "Catalog v1 world-object pointers + counts (T-090.2/.3). Optional until first object export.",
      "additionalProperties": false,
      "properties": {
        "schemaVersion": { "type": "string" },
        "format": { "type": "string" },
        "prefabsPath": { "type": "string" },
        "prefabCount": { "type": "integer", "minimum": 0 },
        "instanceCount": { "type": "integer", "minimum": 0 },
        "chunksPath": { "type": "string" },
        "chunkSizeM": { "type": "number" },
        "roadsPath": { "type": "string" },
        "regionsPath": { "type": "string" },
        "importPhaseMax": { "type": "string" },
        "importPhaseShipped": { "type": "array", "items": { "type": "string" } },
        "typeInventoryPath": {
          "type": "string",
          "description": "Relative path to type-inventory.json — exact prefab/instance counts (T-090.2)."
        },
        "exportedAt": { "type": "string", "format": "date-time" }
      }
    },
    "glyphs": {
      "type": "object",
      "description": "World-object SVG/atlas pointers (T-090.5). Optional.",
      "additionalProperties": false,
      "properties": {
        "manifestPath": { "type": "string" },
        "atlasPath": { "type": "string" },
        "atlasJsonPath": { "type": "string" }
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x", "z"],
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "number" },
          "z": { "type": "number" },
          "surfaceYM": { "type": "number" },
          "demYM": { "type": "number" },
          "note": { "type": "string" }
        }
      }
    },
    "precision": {
      "type": "object",
      "required": ["storageDecimals", "demNativeMetersPerPixel", "spawnAuthority"],
      "properties": {
        "storageDecimals": { "type": "integer", "minimum": 0, "maximum": 6 },
        "demNativeMetersPerPixel": { "type": "number" },
        "spawnAuthority": { "const": "mod-get-surface-y" }
      }
    }
  }
}
