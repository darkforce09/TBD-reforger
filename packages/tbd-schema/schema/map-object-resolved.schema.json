{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.tbdevent.eu/map-object-resolved/v1.json",
  "title": "TBD ResolvedWorldObject (Eden AI + T-090.7 read contract)",
  "description": "Join of catalog instance + prefab (+ optional audit overlay). Every AI tool and the human inspect panel (T-090.9) receive this exact shape — do not invent parallel field names in frontend AI code.",
  "type": "object",
  "required": ["id", "prefabId", "resourceName", "kind", "class", "label", "taxonomyPath", "summary", "x", "y", "z", "rotationDeg", "spatial", "gameplay", "tags"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "prefabId": { "type": "integer", "minimum": 0 },
    "resourceName": { "type": "string", "pattern": "^\\{[0-9A-F]{16}\\}[A-Za-z0-9/_.\\-]+$" },
    "kind": { "$ref": "https://schema.tbdevent.eu/map-object-enums/v1.json#/$defs/kind" },
    "class": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "taxonomyPath": { "type": "string" },
    "summary": { "type": "string" },
    "x": { "type": "number" },
    "y": { "type": "number" },
    "z": { "type": ["number", "null"] },
    "rotationDeg": { "type": "number" },
    "pitchDeg": { "type": "number" },
    "rollDeg": { "type": "number" },
    "spatial": { "$ref": "https://schema.tbdevent.eu/map-object-prefab/v1.json#/properties/spatial" },
    "gameplay": { "$ref": "https://schema.tbdevent.eu/map-object-prefab/v1.json#/properties/gameplay" },
    "geometry": {
      "type": "object",
      "description": "Optional kind-specific geometry: line (roads) or polygon (building footprint when N6 footprint export is proven).",
      "additionalProperties": true
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "description": "Placement quality overlay from T-090.4 / T-090.6 (Z-trust badge in the inspect panel).",
      "properties": {
        "zDeltaM": { "type": "number" },
        "severity": { "type": "string", "enum": ["ok", "warn", "fail"] },
        "visibleAboveGroundPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "maxBurialM": { "type": "number" }
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
