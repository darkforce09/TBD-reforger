# Server
PORT=8080
BASE_URL=http://localhost:8080
ENV=development

# PostgreSQL (use DATABASE_URL or individual vars)
DATABASE_URL=postgres://tbdevent:tbdevent@localhost:5432/tbdevent?sslmode=disable
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=tbdevent
# POSTGRES_PASSWORD=tbdevent
# POSTGRES_DB=tbdevent

# Sessions (required in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback

# Admin access (at least one should be set for CMS)
DISCORD_GUILD_ID=
ADMIN_DISCORD_ROLE_ID=
ADMIN_DISCORD_IDS=

# Game server API (Phase 0.1 REST spike)
# Comma-separated bearer tokens accepted from dedicated game servers.
GAME_SERVER_TOKENS=
# Directory holding compiled mission JSON served at /api/missions/{id}/compiled.
MISSIONS_DIR=missions
# Path to tbd-schema for Mission JSON upload validation (relative to Tbdevent_Website).
SCHEMA_DIR=../tbd-schema
